#!/bin/bash
# Steam UI update hook. Armada does not have a public update channel yet.
set -uo pipefail

while [[ $# -gt 0 ]]; do
    case "$1" in
        --supports-duplicate-detection)
            exit 0
            ;;
    esac
    shift
done

echo "Armada updates are not available on this image." >&2
exit 7
