#!/bin/bash
# armada GPU/CPU clock policy: game | balanced | suspend | resume | status
set -uo pipefail

[[ -r /run/armada/paths.env ]] && source /run/armada/paths.env
eval "$(/usr/libexec/armada/device-env 2>/dev/null)" || true

GPU="${ARMADA_GPU_DEVFREQ:-}"
if [[ -z "$GPU" || ! -d "$GPU" ]]; then
    echo "ERROR: GPU devfreq path not found (is armada-perf-paths.service up?)" >&2
    exit 1
fi

SAVE=/run/armada/power-control.suspend-save
gpu_max=$(cat "$GPU/max_freq")
gpu_stock_min=$(tr ' ' '\n' < "$GPU/available_frequencies" | grep -E '^[0-9]+$' | sort -n | head -1)
floor=$(( ${ARMADA_GPU_GAME_FLOOR_MHZ:-680} * 1000000 ))
if (( floor > gpu_max )); then floor=$gpu_max; fi

w() { echo "$1" > "$2" 2>/dev/null || true; }

case "${1:-balanced}" in
    game)     w "$floor" "$GPU/min_freq" ;;
    balanced) w "$gpu_stock_min" "$GPU/min_freq" ;;
    suspend)
        mkdir -p "$(dirname "$SAVE")"
        : > "$SAVE"
        for p in /sys/devices/system/cpu/cpufreq/policy*/; do
            echo "cpu_max $p $(cat "$p/scaling_max_freq" 2>/dev/null)" >> "$SAVE"
        done
        echo "gpu_min $(cat "$GPU/min_freq")" >> "$SAVE"
        echo "gpu_max $(cat "$GPU/max_freq")" >> "$SAVE"
        w "$gpu_stock_min" "$GPU/min_freq"
        w "$gpu_stock_min" "$GPU/max_freq"
        for p in /sys/devices/system/cpu/cpufreq/policy*/; do
            cmin=$(cat "$p/cpuinfo_min_freq" 2>/dev/null || cat "$p/scaling_min_freq" 2>/dev/null) || continue
            w "$cmin" "$p/scaling_max_freq"
        done
        ;;
    resume)
        [[ -f "$SAVE" ]] || exit 0
        gmax=$(awk '$1=="gpu_max"{print $2}' "$SAVE")
        gmin=$(awk '$1=="gpu_min"{print $2}' "$SAVE")
        [[ -n "$gmax" ]] && w "$gmax" "$GPU/max_freq"
        [[ -n "$gmin" ]] && w "$gmin" "$GPU/min_freq"
        while read -r tag p val; do
            [[ "$tag" == cpu_max && -n "${val:-}" ]] && w "$val" "$p/scaling_max_freq"
        done < "$SAVE"
        rm -f "$SAVE"
        ;;
    status)
        printf 'GPU %s MHz [min %s, max %s], floor target %s MHz\n' \
            "$(( $(cat "$GPU/cur_freq")/1000000 ))" \
            "$(( $(cat "$GPU/min_freq")/1000000 ))" \
            "$(( $(cat "$GPU/max_freq")/1000000 ))" \
            "$(( floor/1000000 ))"
        ;;
    *) echo "Usage: $0 {game|balanced|suspend|resume|status}" >&2; exit 2 ;;
esac
