#!/usr/bin/python3
# Translate bootc's --progress-fd JSON into the N% lines Steam reads off
# steamos-update stdout. Download (ProgressBytes) -> 0-95% from bytes (bootc's
# cumulative byte counter); staging (ProgressSteps) -> 95-100%; forward-only.
import sys, json

last = -1


def emit(pct):
    global last
    pct = int(pct)
    if pct > last and pct <= 100:
        print(f"{pct}%", flush=True)
        last = pct


for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        e = json.loads(line)
    except ValueError:
        continue
    t = e.get("type")
    if t == "ProgressBytes":
        total = e.get("bytesTotal") or 0
        if total:
            done = e.get("bytesCached", 0) + e.get("bytes", 0)
            emit(min(95, done * 95 / total))
    elif t == "ProgressSteps":
        total = e.get("stepsTotal") or 0
        if total:
            done = e.get("stepsCached", 0) + e.get("steps", 0)
            emit(95 + done * 5 / total)
