#!/bin/bash
# Discover dynamic perf-control sysfs paths.
set -euo pipefail

OUT=/run/armada/paths.env
mkdir -p "$(dirname "$OUT")"

TEMP_SENSORS=()
for zone in /sys/devices/virtual/thermal/thermal_zone*/; do
    [[ -r "${zone}type" ]] || continue
    type=$(cat "${zone}type")
    case "${type}" in
        cpu*|gpuss*) TEMP_SENSORS+=("${zone}temp") ;;
    esac
done

GPU_DEVFREQ=""
for p in /sys/devices/platform/soc@0/3d00000.gpu/devfreq/3d00000.gpu \
         /sys/class/devfreq/*.gpu \
         /sys/class/devfreq/*; do
    if [[ -d "$p" && -f "$p/governor" ]]; then
        GPU_DEVFREQ="$p"
        break
    fi
done

{
    echo "# Generated by armada-perf-paths.service"
    echo "ARMADA_TEMP_SENSORS='${TEMP_SENSORS[*]:-}'"
    echo "ARMADA_GPU_DEVFREQ='${GPU_DEVFREQ}'"
    for policy in /sys/devices/system/cpu/cpufreq/policy*/; do
        n=$(basename "$policy" | sed 's/policy//')
        echo "ARMADA_CPU_POLICY_${n}='${policy%/}'"
    done
} > "$OUT"

echo "Wrote: $OUT"
