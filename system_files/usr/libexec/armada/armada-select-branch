#!/bin/bash
# Steam UI "OS Update Channel" hook (steamos-select-branch). Records the chosen
# channel; steamos-update does the download later, so it shows a progress bar.
set -uo pipefail
source /usr/lib/armada/update-lib

case "${1:-}" in
    -l)
        for ch in ${ARMADA_CHANNELS}; do armada_channel_to_token "$ch"; done
        ;;
    -c)
        armada_channel_to_token "$(armada_desired_channel)"
        ;;
    *)
        channel=$(armada_token_to_channel "$1") || { echo "usage: steamos-select-branch <-l|-c|rel|beta|main>" >&2; exit 1; }
        mkdir -p "$(dirname "$ARMADA_CHANNEL_STATE")"
        printf '%s\n' "$channel" > "$ARMADA_CHANNEL_STATE"
        ;;
esac
