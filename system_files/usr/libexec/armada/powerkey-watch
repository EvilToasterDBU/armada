#!/bin/bash
# logind ignores power; real S3 hangs.
set -uo pipefail
LOG_TAG="armada-powerkey"
log() { logger -t "$LOG_TAG" -- "$*"; }

find_power_dev() {
    local dev name
    for dev in /dev/input/event*; do
        [[ -e "$dev" ]] || continue
        name=$(cat "/sys/class/input/$(basename "$dev")/device/name" 2>/dev/null) || continue
        case "$name" in
            *pwrkey*|*Power\ Button*) echo "$dev"; return 0 ;;
        esac
    done
    return 1
}

while true; do
    DEV=$(find_power_dev) || { sleep 2; continue; }
    log "watching $DEV"
    evtest "$DEV" 2>/dev/null | while read -r line; do
        case "$line" in
            *"(KEY_POWER), value 1"*)
                log "power pressed -> toggle fake suspend"
                /usr/libexec/armada/fake-suspend toggle || true
                ;;
        esac
    done
    log "evtest exited for $DEV; rescanning in 1s"
    sleep 1
done
