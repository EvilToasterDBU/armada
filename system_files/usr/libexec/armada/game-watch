#!/bin/bash
set -uo pipefail
prev=""
while :; do
    if pgrep -f 'reaper SteamLaunch AppId=' >/dev/null 2>&1; then
        state=game
    else
        state=balanced
    fi
    if [[ "$state" != "$prev" ]]; then
        /usr/libexec/armada/power-control "$state"
        logger -t armada-game-watch "power state -> $state"
        prev="$state"
    fi
    sleep 5
done
